{
  "_comment": "Minimal public example. Copy to gateway.config.json (gitignored) and adapt. See doc/ARCHITECTURE.md and packages/capability-gateway for full schema.",
  "channels": [
    {
      "id": "slack-incoming",
      "type": "webhook",
      "url": "https://hooks.slack.com/services/XXX/YYY/ZZZ",
      "payloadMode": "json_text"
    },
    {
      "id": "feishu-reply",
      "type": "feishu_bot",
      "url": "REPLACE_WITH_RECEIVE_ID_OR_CHAT_ID",
      "feishuReceiveIdType": "chat_id"
    },
    {
      "id": "wecom-digest",
      "type": "wecom_group_bot",
      "url": "https://qyapi.weixin.qq.com/cgi-bin/webhook/send",
      "wecomKey": "YOUR_GROUP_BOT_KEY"
    }
  ],
  "providers": {
    "feishu": {
      "enabled": false,
      "verificationToken": "FROM_FEISHU_CONSOLE",
      "encryptKey": "",
      "defaultAgentId": "main",
      "replyChannelId": "feishu-reply"
    },
    "wecom": {
      "enabled": false,
      "bridgeSecret": "",
      "defaultAgentId": "main",
      "replyChannelId": "wecom-digest"
    }
  },
  "agentRoutes": [
    {
      "agentId": "main",
      "stickySession": true
    }
  ],
  "learn": {
    "_comment": "Research + technical RSS only (arxiv categories, hnrss narrow queries, HF/GitHub Research/engineering blogs). Copy to gateway.config.json and extend; avoid raw HN + Nitter for lower inbox noise.",
    "feeds": [
      "http://export.arxiv.org/rss/cs.CL",
      "http://export.arxiv.org/rss/cs.AI",
      "http://export.arxiv.org/rss/cs.LG",
      "https://hnrss.org/newest?points=200&q=arxiv",
      "https://hnrss.org/newest?q=Model+Context+Protocol",
      "https://huggingface.co/blog/feed.xml",
      "https://github.blog/ai-and-ml/feed/",
      "https://blog.research.google/feeds/posts/default",
      "https://www.latent.space/feed"
    ],
    "skillsSubdir": "skills",
    "maxItemsPerFeed": 8
  }
}
