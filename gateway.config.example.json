{
  "_comment": "Minimal public example. Copy to gateway.config.json (gitignored) and adapt. See doc/ARCHITECTURE.md and packages/capability-gateway for full schema.",
  "channels": [
    {
      "id": "slack-incoming",
      "type": "webhook",
      "url": "https://hooks.slack.com/services/XXX/YYY/ZZZ",
      "payloadMode": "json_text"
    },
    {
      "id": "feishu-reply",
      "type": "feishu_bot",
      "url": "REPLACE_WITH_RECEIVE_ID_OR_CHAT_ID",
      "feishuReceiveIdType": "chat_id"
    },
    {
      "id": "wecom-digest",
      "type": "wecom_group_bot",
      "url": "https://qyapi.weixin.qq.com/cgi-bin/webhook/send",
      "wecomKey": "YOUR_GROUP_BOT_KEY"
    }
  ],
  "providers": {
    "feishu": {
      "enabled": false,
      "verificationToken": "FROM_FEISHU_CONSOLE",
      "encryptKey": "",
      "defaultAgentId": "main",
      "replyChannelId": "feishu-reply"
    },
    "wecom": {
      "enabled": false,
      "bridgeSecret": "",
      "defaultAgentId": "main",
      "replyChannelId": "wecom-digest"
    }
  },
  "agentRoutes": [
    {
      "agentId": "main",
      "stickySession": true
    }
  ],
  "learn": {
    "_comment": "Curated short feed list — keep <=10 reachable sources by default; users add their own (extra Nitter mirrors, etc.) in their local gateway.config.json.",
    "feeds": [
      "https://news.ycombinator.com/rss",
      "https://hnrss.org/newest?q=AI%20agent",
      "https://hnrss.org/newest?q=Model+Context+Protocol",
      "https://blog.langchain.dev/rss/",
      "https://simonwillison.net/atom/everything/",
      "http://export.arxiv.org/rss/cs.CL",
      "https://github.blog/ai-and-ml/feed/",
      "https://www.latent.space/feed",
      "https://lastweekin.ai/feed"
    ],
    "skillsSubdir": "skills",
    "maxItemsPerFeed": 12
  }
}
