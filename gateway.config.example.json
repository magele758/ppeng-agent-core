    "wecom": {
      "enabled": false,
      "bridgeSecret": "",
      "defaultAgentId": "main",
      "replyChannelId": "wecom-digest"
    }
  },
  "agentRoutes": [
    {
      "agentId": "main",
      "stickySession": true
    }
  ],
  "learn": {
    "feeds": [
      "https://hnrss.org/newest?q=AI+agent",
      "https://hnrss.org/newest?q=LLM+tool"
