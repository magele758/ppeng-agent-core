# Cursor 全链路 + Codex Review 管线
#   研究 / 规划 / 实现 / 精炼   → cursor-agent (composer-2-fast)
#   审查 (review)              → codex CLI
#
# 使用：
#   1) 一次性手动跑：npm run evolution:run-cursor-codex
#   2) 写进 .env 长期生效：cat scripts/evolution-cursor-codex.env.example >> .env
#      然后 npm run evolution:pipeline 时确保设了 EVOLUTION_PIPELINE_USE_ENV_AGENT=1
#
# 前置：本机已安装并登录 cursor `agent`、`codex`（见 doc/EXTERNAL_AI_CLI.md）

# ── 让 npm run evolution:pipeline 沿用以下 EVOLUTION_AGENT_CMD（否则会被强制覆盖为 Claude） ──
EVOLUTION_PIPELINE_USE_ENV_AGENT=1

# ── Cursor 模型设置 ──
# 实现阶段（多数 item，省钱省时）
EVOLUTION_CURSOR_AGENT_MODEL=composer-2-fast
# 审查 / 精炼 / rebase 冲突（AI_FIX_PROMPT）用；不设则与 EVOLUTION_CURSOR_AGENT_MODEL 相同（见 evolution-agent-cursor.sh）
EVOLUTION_CURSOR_AGENT_REVIEW_MODEL=composer-2-fast

# ── 0) 跳过 PLAN 阶段：cursor 自己会规划，不再叫 codex 写 dev-plan ──
EVOLUTION_SKIP_PLAN=1

# ── 1) 研究：cursor 评估 PROCEED / SKIP ──
EVOLUTION_RESEARCH_CMD=bash scripts/evolution-research-cursor.sh

# ── 2) 实现：cursor 改代码 ──
EVOLUTION_AGENT_CMD=bash scripts/evolution-agent-cursor.sh

# ── 3) 审查：codex review；不通过则 cursor 精炼 ──
EVOLUTION_REVIEW_CMD=bash scripts/evolution-codex-prompt.sh
EVOLUTION_REFINE_CMD=bash scripts/evolution-agent-cursor.sh
EVOLUTION_REVIEW_MAX_ROUNDS=3
EVOLUTION_REVIEW_DIFF_MAX_CHARS=56000

# ── 调度（按 inbox 待处理条目数自适应；不限上限就别设 EVOLUTION_MAX_ITEMS）──
EVOLUTION_TARGET_BRANCH=main
EVOLUTION_AUTO_MERGE=0           # 先稳一阵再开自动合并
EVOLUTION_CONCURRENCY=3          # cursor agent 本地资源充足可加到 5
# EVOLUTION_MAX_ITEMS=10         # 留空 = 处理所有未处理 inbox 条目（用于消化你之前积压的 learn）

# ── 构建 / 测试门禁（与默认链路一致） ──
EVOLUTION_BUILD_CMD=npx tsc -b packages/core packages/capability-gateway
EVOLUTION_TEST_CMD=npm run test:unit

# ── 可选：rebase 冲突仍交给 codex ──
EVOLUTION_REBASE_CONFLICT_CMD=bash scripts/evolution-rebase-conflict-codex.sh
