# 完整质量链路：研究 → Codex 规划 → Claude 实现 → Gemini 测试补强 → 单测
#        → Codex 审查 / Claude 精炼 → rebase（Codex 解冲突）→ 合并主分支
#
# 用法（在仓库根目录）：
#   cat scripts/evolution-quality-pipeline.env.example >> .env
# 再按需编辑；需本机已安装并登录：claude / codex / gemini（PATH 可找到命令）。
#
# 一键跑：npm run evolution:pipeline
# （EVOLUTION_PIPELINE_USE_ENV_AGENT=1 时 pipeline 不再覆盖你的 EVOLUTION_AGENT_CMD）

# ========== npm run evolution:pipeline ==========
EVOLUTION_PIPELINE_USE_ENV_AGENT=1
EVOLUTION_SKIP_PIPELINE_BUILD=0
EVOLUTION_PIPELINE_BUILD_CMD=npx tsc -b packages/capability-gateway
EVOLUTION_PIPELINE_LEARN_ONLY=0
EVOLUTION_POST_MERGE_RELOAD=0
EVOLUTION_POST_MERGE_BUILD_CMD=npm run build
EVOLUTION_RELOAD_DAEMON=0

# ========== evolution:learn（摄入 inbox）==========
EVOLUTION_GATEWAY_CONFIG=./gateway.config.json
# EVOLUTION_LOCAL_SOURCES=.evolution/sources/,doc/evolution/local/
# EVOLUTION_ARCHIVE_DIR=doc/evolution/archive/

# ========== evolution:run-day 调度 ==========
EVOLUTION_TARGET_BRANCH=main
EVOLUTION_AUTO_MERGE=1
EVOLUTION_ALLOW_DIRTY_MAIN=0
EVOLUTION_ALLOW_DIRTY_WORKTREE=0
EVOLUTION_CONCURRENCY=3
# EVOLUTION_MAX_ITEMS=5
EVOLUTION_ROUNDS_PER_DAY=1
EVOLUTION_ROUND_INTERVAL_MS=0
EVOLUTION_LINK_FETCH_MS=25000
EVOLUTION_NO_RUN_LOG=0
EVOLUTION_SKIP_COPY_ENV=0
EVOLUTION_SKIP_COPY_GATEWAY_CONFIG=0
EVOLUTION_PRESERVE_SELF_HEAL_ENV=0

# ========== 构建与门禁测试 ==========
EVOLUTION_BUILD_CMD=npx tsc -b packages/core packages/capability-gateway
EVOLUTION_SKIP_BUILD=0
EVOLUTION_SKIP_NPM_CI=0
EVOLUTION_TEST_CMD='npm run test:unit'

# ========== 1) 研究（可选，在规划/实现之前）==========
EVOLUTION_RESEARCH_CMD='bash scripts/evolution-research.sh'

# ========== 2) 规划：Codex 写 .evolution/dev-plan.md ==========
EVOLUTION_PLAN_CMD='bash scripts/evolution-codex-prompt.sh'
EVOLUTION_SKIP_PLAN=0

# ========== 3) 实现：Claude Code（Coding）==========
EVOLUTION_AGENT_CMD='bash scripts/evolution-agent-claude.sh'

# ========== 4) 测试补强：Gemini（构建后、首次单测前）==========
EVOLUTION_TEST_AGENT_CMD='bash scripts/evolution-test-agent-gemini.sh'
# 与 EVOLUTION_AGENT_CLI_PROMPT_MAX_CHARS 配合；默认已降到 56000，过大易导致 CLI 参数过长失败
EVOLUTION_TEST_AGENT_DIFF_MAX_CHARS=56000
EVOLUTION_SKIP_TEST_AGENT=0

# ========== 5) 审查：Codex；未通过则精炼：Claude ==========
EVOLUTION_REVIEW_CMD='bash scripts/evolution-codex-prompt.sh'
EVOLUTION_REFINE_CMD='bash scripts/evolution-agent-claude.sh'
EVOLUTION_REVIEW_MAX_ROUNDS=5
EVOLUTION_REVIEW_DIFF_MAX_CHARS=56000

# ========== 6) rebase 目标分支；冲突用 Codex ==========
EVOLUTION_SKIP_REBASE=0
EVOLUTION_REBASE_CONFLICT_CMD='bash scripts/evolution-rebase-conflict-codex.sh'
EVOLUTION_REBASE_CONFLICT_MAX_ROUNDS=8
EVOLUTION_REBASE_DISABLE_CODEX_DEFAULT=0

# ========== Codex 沙箱（可选：隔离环境可设 AI_CODEX_FULL_AUTO=1）==========
AI_CODEX_FULL_AUTO=0

# ========== 项目约束（可选）==========
# EVOLUTION_AGENT_CONSTRAINTS_FILE=doc/evolution/agent-constraints.md
# EVOLUTION_AGENT_CONSTRAINTS=

# ========== 多 CLI 实现时可改用（与上方 EVOLUTION_AGENT_CMD 二选一）==========
# EVOLUTION_AGENT_CMD='bash scripts/evolution-agent-multi.sh'
# EVOLUTION_AGENT_STRATEGY=rotate
# EVOLUTION_AGENT_WEIGHTS=claude:2,codex:1,cursor:1
# 主 CLI 非零退出（额度/限流等）时再试 Cursor agent（PATH 需有 `agent`）：
# EVOLUTION_AGENT_QUOTA_FALLBACK=cursor
# EVOLUTION_AGENT_DIFFICULTY_MAP=simple:codex,medium:cursor,complex:claude
# EVOLUTION_CLI_AUTO_UPDATE=0
# EVOLUTION_CLI_SKIP_UPDATE=0
