{
  "name": "@ppeng/agent-core",
  "version": "0.1.0",
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "jsonrepair": "^3.12.0",
    "pg": "^8.13.1",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10"
  },
  "//": "sharp moved to optionalDependencies — lazy-loaded in src/image-assets.ts so installs that skip it (e.g. unsupported arch) still produce a working agent (contact-sheet retention disabled).",
  "optionalDependencies": {
    "sharp": "^0.33.5"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./session-query": {
      "types": "./dist/session-query.d.ts",
      "default": "./dist/session-query.js"
    }
  }
}
