{
  "version": "0.2.0",
  // Next 路径：多数 workspace 会提升到根 node_modules；若启动失败可改为 apps/web-console/node_modules/.../next
  "configurations": [
    {
      "name": "Daemon (7070)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/apps/daemon/dist/server.js",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Web Console (Next 13000)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/web-console",
      "program": "${workspaceFolder}/node_modules/next/dist/bin/next",
      "args": ["dev", "--turbopack", "-p", "13000"],
      "env": {
        "DAEMON_PROXY_TARGET": "http://127.0.0.1:7070"
      },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "CLI",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/apps/cli/dist/index.js",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Attach :9229",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Lab: Daemon + Web",
      "configurations": ["Daemon (7070)", "Web Console (Next 13000)"],
      "stopAll": true
    }
  ]
}
