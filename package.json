{
  "name": "my-raw-agent-sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/core packages/capability-gateway apps/daemon apps/cli && npm run build:web-console",
    "test": "npm run build && npm run test:unit",
    "test:unit": "node --test packages/core/test/*.test.js packages/capability-gateway/test/*.test.js",
    "test:regression": "node scripts/regression-test.mjs",
    "test:e2e": "node scripts/e2e-run.mjs",
    "test:e2e:install": "playwright install --with-deps chromium",
    "ai:tools": "bash scripts/ai-cli/check-tools.sh",
    "ai:claude": "bash scripts/ai-cli/run-claude-fix.sh",
    "ai:codex": "bash scripts/ai-cli/run-codex-fix.sh",
    "ai:cursor": "bash scripts/ai-cli/run-cursor-agent-fix.sh",
    "test:remote": "node scripts/remote-smoke.mjs",
    "ci": "npm run build && npm run test:unit && npm run test:regression && npm run test:e2e",
    "start:daemon": "node apps/daemon/dist/server.js",
    "start:supervised": "node scripts/supervisor.mjs",
    "self-heal:flow": "bash scripts/self-heal-flow.sh",
    "start:cli": "node apps/cli/dist/index.js",
    "dev:daemon": "npx tsc -b packages/core apps/daemon && node apps/daemon/dist/server.js",
    "dev:cli": "node --experimental-strip-types apps/cli/src/index.ts",
    "dev:web-console": "npm run dev --workspace=@ppeng/agent-lab-web",
    "evolution:learn": "node scripts/evolution-learn.mjs",
    "evolution:run-day": "node scripts/evolution-run-day.mjs",
    "evolution:pipeline": "bash scripts/evolution-pipeline.sh",
    "evolution:post-merge-reload": "bash scripts/evolution-post-merge-reload.sh",
    "evolution:run-full": "EVOLUTION_AGENT_CMD='bash scripts/evolution-agent-full.sh' node scripts/evolution-run-day.mjs",
    "evolution:run-cursor-codex": "EVOLUTION_RESEARCH_CMD='bash scripts/evolution-research-cursor.sh' EVOLUTION_AGENT_CMD='bash scripts/evolution-agent-cursor.sh' EVOLUTION_REVIEW_CMD='bash scripts/evolution-codex-prompt.sh' EVOLUTION_REFINE_CMD='bash scripts/evolution-agent-cursor.sh' node scripts/evolution-run-day.mjs",
    "build:web-console": "npm run build --workspace=@ppeng/agent-lab-web",
    "start:web-console": "npm run start --workspace=@ppeng/agent-lab-web",
    "dev": "node scripts/dev-lab.mjs",
    "dev:lab": "npm run dev"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.3.1",
    "vscode-jsonrpc": "^8.2.1",
    "yaml": "^2.8.3"
  }
}
