{
  "name": "my-raw-agent-sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/core packages/capability-gateway apps/daemon apps/cli",
    "test": "npm run build && npm run test:unit",
    "test:unit": "node --test packages/core/test/*.test.js packages/capability-gateway/test/*.test.js",
    "test:regression": "node scripts/regression-test.mjs",
    "test:e2e": "node scripts/e2e-run.mjs",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:remote": "node scripts/remote-smoke.mjs",
    "ci": "npm run build && npm run test:unit && npm run test:regression && npm run test:e2e",
    "start:daemon": "node apps/daemon/dist/server.js",
    "start:cli": "node apps/cli/dist/index.js",
    "dev:daemon": "node --experimental-strip-types apps/daemon/src/server.ts",
    "dev:cli": "node --experimental-strip-types apps/cli/src/index.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
