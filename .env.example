# Raw Agent SDK 配置示例
# 复制为 .env 并填写实际值: cp .env.example .env
#
# CI / GitHub Actions：见 docs/CI.md（每次 push/PR 自动 build+测试；可选 Secrets 跑真模型冒烟）

# 模型提供商: heuristic | openai-compatible | anthropic-compatible
RAW_AGENT_MODEL_PROVIDER=openai-compatible

# OpenAI 兼容 API (chat completions)
RAW_AGENT_BASE_URL=https://api.openai.com/v1
RAW_AGENT_API_KEY=sk-your-api-key
RAW_AGENT_MODEL_NAME=gpt-4
# 控制 OpenAI 兼容适配器在 summary 压缩时是否发送 response_format=json_object
# 若第三方 API 不支持 response_format，设为 0 或 false
# RAW_AGENT_USE_JSON_MODE=0

# --- 视觉 / VL（openai-compatible 时可选；设置后自动 hybrid-router，含图消息走 VL）---
# RAW_AGENT_VL_MODEL_NAME=qwen-vl-plus
# RAW_AGENT_VL_BASE_URL=https://api.example.com/v1
# RAW_AGENT_VL_API_KEY=
# RAW_AGENT_VL_USE_JSON_MODE=0
# 何时走 VL：any（任一条消息含图）| last_user（仅当最后一轮用户消息含图）
# RAW_AGENT_VL_ROUTE_SCOPE=any
# 图片：单文件最大字节；热图保留数量；关键帧模型（关掉则仅用启发式抽样）
# RAW_AGENT_IMAGE_MAX_BYTES=12000000
# RAW_AGENT_IMAGE_FETCH_TIMEOUT_MS=30000
# RAW_AGENT_IMAGE_HOT_LIMIT=3
# RAW_AGENT_IMAGE_WARM_KEYFRAME_LIMIT=4
# RAW_AGENT_IMAGE_CONTACT_SHEET_GRID=2
# RAW_AGENT_IMAGE_RETENTION_DAYS=30
# RAW_AGENT_IMAGE_KEYFRAME_MODEL=1

# Anthropic 兼容 API (可选)
# RAW_AGENT_ANTHROPIC_URL=https://api.anthropic.com/v1

# E2E/CI：由 scripts/e2e-run.mjs 自动设为 1，daemon 内会强制 heuristic 并忽略远程 OpenAI 等，避免本机 .env 污染自动化
# RAW_AGENT_E2E_ISOLATE=1

# Next 控制台本地代理 daemon（npm run dev:web-console / start:web-console 时在 shell 里 export）
# DAEMON_PROXY_TARGET=http://127.0.0.1:7070

# Daemon
RAW_AGENT_DAEMON_HOST=127.0.0.1
RAW_AGENT_DAEMON_PORT=7070
# 浏览器跨域：逗号分隔 Origin，或 *（慎用）
# RAW_AGENT_CORS_ORIGIN=http://127.0.0.1:5173

# 状态目录
# RAW_AGENT_STATE_DIR=.agent-state

# 上下文压缩：估算 token 阈值（约 4 字符/token）
# RAW_AGENT_COMPACT_TOKEN_THRESHOLD=24000

# 单轮并行执行的工具调用数上限
# RAW_AGENT_MAX_PARALLEL_TOOLS=8

# 模型 runTurn 失败重试次数
# RAW_AGENT_MODEL_MAX_RETRIES=2

# bash 默认超时（毫秒）
# RAW_AGENT_BASH_TIMEOUT_MS=120000

# 为 true/1 时，向模型挂载工具 claude_code / codex_exec / cursor_agent，可在会话内自主调用外部 CLI（需本机 PATH 有对应命令；默认每次调用需审批）
# RAW_AGENT_EXTERNAL_AI_TOOLS=1

# --- Self-heal（CLI：`npm run start:cli -- self-heal start`；HTTP：`POST /api/self-heal/start`）---
# RAW_AGENT_SELF_HEAL_TEST_PRESET=unit
# RAW_AGENT_SELF_HEAL_CUSTOM_SCRIPT=myscript
# RAW_AGENT_SELF_HEAL_MAX_ITERATIONS=5
# RAW_AGENT_SELF_HEAL_AUTO_MERGE=0
# RAW_AGENT_SELF_HEAL_AUTO_RESTART=0
# RAW_AGENT_SELF_HEAL_TARGET_BRANCH=main
# RAW_AGENT_SELF_HEAL_AGENT_ID=self-healer
# Allow self-heal agent to call claude_code/codex_exec/cursor_agent without approval
# (requires RAW_AGENT_EXTERNAL_AI_TOOLS=1 and the CLI to be on PATH)
# RAW_AGENT_SELF_HEAL_ALLOW_EXTERNAL_AI=0
# Daemon 启动时自动发起一次 self-heal（policy 仍来自下方 RAW_AGENT_SELF_HEAL_*；与「已有活跃 run」冲突时跳过）
# RAW_AGENT_SELF_HEAL_AUTO_START=0
# merge 前主仓有未提交改动时自动 git stash push -u，merge 成功后 stash pop（失败会 blocked 并提示）
# RAW_AGENT_SELF_HEAL_AUTO_STASH_MAIN=0

# 设为 1 且使用 openai-compatible 时，daemon / runSession(stream) 可走 SSE 流式
# RAW_AGENT_STREAM=1

# 审批策略 JSON，例如: {"defaultRisky":true} 或 {"rules":[{"toolPattern":"write_*","match":"glob","when":"always"}]}
# RAW_AGENT_APPROVAL_POLICY=

# HTTP JSON-RPC MCP 地址，逗号或空格分隔
# RAW_AGENT_MCP_URLS=http://127.0.0.1:3030/mcp

# Daemon 请求体最大字节数
# RAW_AGENT_MAX_BODY_BYTES=2000000

# --- Capability Gateway（与 core 平级包 @ppeng/agent-capability-gateway，HTTP 前缀默认 /gateway/v1）---
# 设为 1 启用；见 gateway.config.example.json
# RAW_AGENT_GATEWAY_ENABLED=1
# RAW_AGENT_GATEWAY_PREFIX=/gateway/v1
# RAW_AGENT_GATEWAY_CONFIG=gateway.config.json
# 可选：X-Gateway-Token 或 Authorization: Bearer
# RAW_AGENT_GATEWAY_TOKEN=
# 定时 RSS 学习（每日 UTC 整点后首次 tick 跑一次）
# RAW_AGENT_GATEWAY_LEARN_ENABLED=1
# RAW_AGENT_GATEWAY_LEARN_HOUR_UTC=6

# 飞书 / Lark 机器人发消息（channels 里 type=feishu_bot 或 Feishu 事件回复）
# RAW_AGENT_FEISHU_APP_ID=
# RAW_AGENT_FEISHU_APP_SECRET=
# 国际版 Lark 时可改 API 根，例如 https://open.larksuite.com
# RAW_AGENT_FEISHU_API_BASE=https://open.feishu.cn
