# Raw Agent SDK 配置示例
# 复制为 .env 并填写实际值: cp .env.example .env
#
# CI / GitHub Actions：见 docs/CI.md（每次 push/PR 自动 build+测试；可选 Secrets 跑真模型冒烟）

# 模型提供商: heuristic | openai-compatible | anthropic-compatible
RAW_AGENT_MODEL_PROVIDER=openai-compatible

# OpenAI 兼容 API (chat completions)
RAW_AGENT_BASE_URL=https://api.openai.com/v1
RAW_AGENT_API_KEY=sk-your-api-key
RAW_AGENT_MODEL_NAME=gpt-4
# 控制 OpenAI 兼容适配器在 summary 压缩时是否发送 response_format=json_object
# 若第三方 API 不支持 response_format，设为 0 或 false
# RAW_AGENT_USE_JSON_MODE=0

# Anthropic 兼容 API (可选)
# RAW_AGENT_ANTHROPIC_URL=https://api.anthropic.com/v1

# Daemon
RAW_AGENT_DAEMON_HOST=127.0.0.1
RAW_AGENT_DAEMON_PORT=7070
# 浏览器跨域：逗号分隔 Origin，或 *（慎用）
# RAW_AGENT_CORS_ORIGIN=http://127.0.0.1:5173

# 状态目录
# RAW_AGENT_STATE_DIR=.agent-state

# 上下文压缩：估算 token 阈值（约 4 字符/token）
# RAW_AGENT_COMPACT_TOKEN_THRESHOLD=24000

# 单轮并行执行的工具调用数上限
# RAW_AGENT_MAX_PARALLEL_TOOLS=8

# 模型 runTurn 失败重试次数
# RAW_AGENT_MODEL_MAX_RETRIES=2

# bash 默认超时（毫秒）
# RAW_AGENT_BASH_TIMEOUT_MS=120000

# 设为 1 且使用 openai-compatible 时，daemon / runSession(stream) 可走 SSE 流式
# RAW_AGENT_STREAM=1

# 审批策略 JSON，例如: {"defaultRisky":true} 或 {"rules":[{"toolPattern":"write_*","match":"glob","when":"always"}]}
# RAW_AGENT_APPROVAL_POLICY=

# HTTP JSON-RPC MCP 地址，逗号或空格分隔
# RAW_AGENT_MCP_URLS=http://127.0.0.1:3030/mcp

# Daemon 请求体最大字节数
# RAW_AGENT_MAX_BODY_BYTES=2000000

# --- Capability Gateway（与 core 平级包 @ppeng/agent-capability-gateway，HTTP 前缀默认 /gateway/v1）---
# 设为 1 启用；见 gateway.config.example.json
# RAW_AGENT_GATEWAY_ENABLED=1
# RAW_AGENT_GATEWAY_PREFIX=/gateway/v1
# RAW_AGENT_GATEWAY_CONFIG=gateway.config.json
# 可选：X-Gateway-Token 或 Authorization: Bearer
# RAW_AGENT_GATEWAY_TOKEN=
# 定时 RSS 学习（每日 UTC 整点后首次 tick 跑一次）
# RAW_AGENT_GATEWAY_LEARN_ENABLED=1
# RAW_AGENT_GATEWAY_LEARN_HOUR_UTC=6

# 飞书 / Lark 机器人发消息（channels 里 type=feishu_bot 或 Feishu 事件回复）
# RAW_AGENT_FEISHU_APP_ID=
# RAW_AGENT_FEISHU_APP_SECRET=
# 国际版 Lark 时可改 API 根，例如 https://open.larksuite.com
# RAW_AGENT_FEISHU_API_BASE=https://open.feishu.cn
