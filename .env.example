# Raw Agent SDK 配置示例
# 复制为 .env 并填写实际值: cp .env.example .env
#
# 须为 bash 可 `source` 的 KEY=value；勿粘贴 YAML（如单独一行 `run: deploy` 会报「run: 未找到命令」）。
# 含空格的命令须加引号，例如 EVOLUTION_TEST_CMD='npm run test:unit'（否则 `run` 会被当成独立命令执行）。
#
# CI / GitHub Actions：见 docs/CI.md（每次 push/PR 自动 build+测试；可选 Secrets 跑真模型冒烟）

# 模型提供商: heuristic | openai-compatible | anthropic-compatible
RAW_AGENT_MODEL_PROVIDER=openai-compatible

# OpenAI 兼容 API (chat completions)
RAW_AGENT_BASE_URL=https://api.openai.com/v1
RAW_AGENT_API_KEY=sk-your-api-key
RAW_AGENT_MODEL_NAME=gpt-4
# 控制 OpenAI 兼容适配器在 summary 压缩时是否发送 response_format=json_object
# 若第三方 API 不支持 response_format，设为 0 或 false
# RAW_AGENT_USE_JSON_MODE=0

# --- 视觉 / VL（openai-compatible 时可选；设置后自动 hybrid-router，含图消息走 VL）---
# RAW_AGENT_VL_MODEL_NAME=qwen-vl-plus
# RAW_AGENT_VL_BASE_URL=https://api.example.com/v1
# RAW_AGENT_VL_API_KEY=
# RAW_AGENT_VL_USE_JSON_MODE=0
# 何时走 VL：any（任一条消息含图）| last_user（仅当最后一轮用户消息含图）
# RAW_AGENT_VL_ROUTE_SCOPE=any
# 图片：单文件最大字节；热图保留数量；关键帧模型（关掉则仅用启发式抽样）
# RAW_AGENT_IMAGE_MAX_BYTES=12000000
# RAW_AGENT_IMAGE_FETCH_TIMEOUT_MS=30000
# RAW_AGENT_IMAGE_HOT_LIMIT=3
# RAW_AGENT_IMAGE_WARM_KEYFRAME_LIMIT=4
# RAW_AGENT_IMAGE_CONTACT_SHEET_GRID=2
# RAW_AGENT_IMAGE_RETENTION_DAYS=30
# RAW_AGENT_IMAGE_KEYFRAME_MODEL=1

# Anthropic 兼容 API (可选)
# RAW_AGENT_ANTHROPIC_URL=https://api.anthropic.com/v1

# E2E/CI：由 scripts/e2e-run.mjs 自动设为 1，daemon 内会强制 heuristic 并忽略远程 OpenAI 等，避免本机 .env 污染自动化
# RAW_AGENT_E2E_ISOLATE=1

# Next 控制台本地代理 daemon（npm run dev:web-console / start:web-console 时在 shell 里 export）
# DAEMON_PROXY_TARGET=http://127.0.0.1:7070

# Daemon
RAW_AGENT_DAEMON_HOST=127.0.0.1
RAW_AGENT_DAEMON_PORT=7070
# 浏览器跨域：逗号分隔 Origin，或 *（慎用）
# RAW_AGENT_CORS_ORIGIN=http://127.0.0.1:13000

# 状态目录
# RAW_AGENT_STATE_DIR=.agent-state

# 上下文压缩：估算 token 阈值（约 4 字符/token）；滚动摘要字符上限（不设则默认 = 阈值×2，与估算口径一致）
# RAW_AGENT_COMPACT_TOKEN_THRESHOLD=24000
# RAW_AGENT_COMPACT_SUMMARY_MAX_CHARS=48000

# 单轮并行执行的工具调用数上限
# RAW_AGENT_MAX_PARALLEL_TOOLS=8

# Skills：除仓库 `skills/**/SKILL.md` 外，默认递归加载 ~/.agents/**/SKILL.md；同名时 ~/.agents 覆盖仓库
# RAW_AGENT_AGENTS_SKILLS=0
# RAW_AGENT_AGENTS_SKILLS_DIR=/custom/path

# Skill 路由：legacy=全文广播 meta + 关键词 Matched；lexical=仅词法 shortlist；hybrid=词法 shortlist ∪ 关键词命中（默认）
# RAW_AGENT_SKILL_ROUTING_MODE=hybrid
# RAW_AGENT_SKILL_ROUTING_TOP_K=8
# 为 1 时 load_skill 仅限当轮 shortlist（否则仍可加载未列出 skill，并写入 trace）
# RAW_AGENT_SKILL_LOAD_STRICT=0

# --- Evolution（自我进化实验：npm run evolution:learn / evolution:run-day）---
# gateway：RSS 源列表在 gateway.config.json 的 learn.feeds（也可用 EVOLUTION_GATEWAY_CONFIG 指向副本）
# EVOLUTION_GATEWAY_CONFIG=./gateway.config.json
#
# 本地信息源目录（git 不跟踪的私有资料，逗号分隔；支持递归扫描子目录）
# EVOLUTION_LOCAL_SOURCES=.evolution/sources/,doc/evolution/local/
# 历史归档目录（已爬取但未测试的资料，会提取 status: pending/research_only/archived 的条目重新加入队列；支持子目录）
# EVOLUTION_ARCHIVE_DIR=doc/evolution/archive/
#
# --- 自进化一键管线（npm run evolution:pipeline，脚本见 scripts/evolution-pipeline.sh）---
# pipeline 默认强制使用 Claude：bash scripts/evolution-agent-claude.sh（忽略 .env 里的 EVOLUTION_AGENT_CMD）
# 若要在 pipeline 中沿用 .env 的 EVOLUTION_AGENT_CMD（如 evolution-agent-multi）：EVOLUTION_PIPELINE_USE_ENV_AGENT=1
# 顺序：可选管线内编译 → evolution:learn → evolution:run-day →（可选）合并后全量 build + 重载 daemon
# EVOLUTION_SKIP_PIPELINE_BUILD=0
# 管线开头编译（learn 至少需要 packages/capability-gateway/dist）
# EVOLUTION_PIPELINE_BUILD_CMD=npx tsc -b packages/capability-gateway
# 仅执行 learn（适合 CI 定时摄入，不跑 worktree / 单测）
# EVOLUTION_PIPELINE_LEARN_ONLY=0
# run-day 结束后若需主仓加载新代码：全量编译 + 可选向 daemon 发 SIGTERM（配合 start:supervised）
# EVOLUTION_POST_MERGE_RELOAD=0
# EVOLUTION_POST_MERGE_BUILD_CMD=npm run build
# EVOLUTION_RELOAD_DAEMON=0
# EVOLUTION_MAX_ITEMS=           # 可选安全帽：每次最多处理 N 条未处理条目（不设 = 全部）；已处理过的条目（success/failure/skip/no-op 均有记录）自动跳过
# EVOLUTION_ROUNDS_PER_DAY=1     # 每天最多运行轮次（不设或 <=0 = 1 轮）；进度保存在 .evolution/runs/{UTC日期}-progress.json
# 同日需再跑一轮：删该 progress 文件，或增大 EVOLUTION_ROUNDS_PER_DAY
# EVOLUTION_ROUND_INTERVAL_MS=0  # 多轮之间的间隔毫秒数（仅当 ROUNDS_PER_DAY > 1 时有效）
# EVOLUTION_ALLOW_DIRTY_MAIN=0   # 当 AUTO_MERGE=1 时，是否允许主分支有未提交改动（默认拒绝，避免合并冲突）
# EVOLUTION_TEST_CMD='npm run test:unit'
# EVOLUTION_SKIP_NPM_CI=0
# EVOLUTION_AUTO_MERGE=0
# EVOLUTION_TARGET_BRANCH=main
# EVOLUTION_ALLOW_DIRTY_WORKTREE=0
# run-day：并行工作数（上限 3；AUTO_MERGE=1 时强制 1）
# EVOLUTION_CONCURRENCY=3
# 抓取 inbox 链接正文的超时（毫秒）
# EVOLUTION_LINK_FETCH_MS=25000
# run-day：npm ci 后编译 TS（test:unit 依赖 dist/，与根目录 npm test 会先 build 不同）
# EVOLUTION_BUILD_CMD=npx tsc -b packages/core packages/capability-gateway
# EVOLUTION_SKIP_BUILD=0
# 不写 runs/latest-*.md（仍会在终端打时间戳日志）
# EVOLUTION_NO_RUN_LOG=0
# run-day：不把主仓 .env 复制进各 worktree（默认会复制，便于在 worktree 目录内手动跑命令）
# EVOLUTION_SKIP_COPY_ENV=0
# run-day：不把 gateway 配置复制进各 worktree（默认会按 EVOLUTION_GATEWAY_CONFIG → gateway.config.json → example 解析源文件并复制）
# EVOLUTION_SKIP_COPY_GATEWAY_CONFIG=0
# run-day：跑 EVOLUTION_TEST_CMD 时保留 RAW_AGENT_SELF_HEAL_*（默认会剥离，避免宿主 .env 导致与 CI 不一致）
# EVOLUTION_PRESERVE_SELF_HEAL_ENV=0
# run-day：npm ci 之后、构建之前执行的 shell（可选）。会写入 worktree/.evolution/source-excerpt.txt 与 constraints.txt，并设置 EVOLUTION_WT_ROOT、EVOLUTION_SOURCE_* 等
# ── 研究阶段（可选）：在 EVOLUTION_AGENT_CMD 之前运行，决定是否值得研发 ──
# EVOLUTION_RESEARCH_CMD='bash scripts/evolution-research.sh'
# 研究脚本向 $EVOLUTION_RESEARCH_DECISION_FILE 写入决策（run-day 会注入；单独跑脚本时默认写到 worktree/.evolution/research-decision.txt）：
#   PROCEED — 继续研发
#   SKIP — 跳过（细分类型：SUPERSEDED/DUPLICATE/IRRELEVANT/OUTDATED/TOO_COMPLEX）
# SUPERSEDED/DUPLICATE 写入 doc/evolution/superseded/（当前实现更优或已有类似实现）
# IRRELEVANT/OUTDATED/TOO_COMPLEX 写入 doc/evolution/no-op/
# ── 实现阶段（可选）：研究通过后执行 ──
# EVOLUTION_AGENT_CMD='bash scripts/evolution-agent-claude.sh'
# 或 Codex：'bash scripts/evolution-agent-codex.sh'
# 多 CLI 路由（按比例或按难度分配给 claude/codex/cursor/gemini）：
# EVOLUTION_AGENT_CMD='bash scripts/evolution-agent-multi.sh'
# EVOLUTION_AGENT_CMD='bash scripts/evolution-agent-hook.example.sh'
# ── CLI 更新检测 ──
# EVOLUTION_CLI_AUTO_UPDATE=0    # 有更新时自动更新 CLI（默认仅提示）
# EVOLUTION_CLI_SKIP_UPDATE=0    # 跳过更新检测
# 多 CLI 路由策略（rotate=权重轮转，difficulty=难度路由；默认 rotate）
# EVOLUTION_AGENT_STRATEGY=rotate
# rotate 模式：各 CLI 的权重（格式 cli名:整数，逗号分隔；cli 名: claude|codex|cursor|gemini）
# EVOLUTION_AGENT_WEIGHTS=claude:2,codex:1,cursor:1
# difficulty 模式：三档难度各自对应的 CLI
# EVOLUTION_AGENT_DIFFICULTY_MAP=simple:codex,medium:cursor,complex:claude
# codex 全绕过沙箱（默认 --full-auto 已自动审批；设 1 改用 --dangerously-bypass-approvals-and-sandbox，适合已外部隔离的环境）
# AI_CODEX_FULL_AUTO=0
# 约束：多行可放文件并由 EVOLUTION_AGENT_CONSTRAINTS_FILE 指向（相对仓库根）；或与 EVOLUTION_AGENT_CONSTRAINTS 二选一
# EVOLUTION_AGENT_CONSTRAINTS_FILE=doc/evolution/agent-constraints.md
# EVOLUTION_AGENT_CONSTRAINTS=

# 模型 runTurn 失败重试次数
# RAW_AGENT_MODEL_MAX_RETRIES=2

# bash 默认超时（毫秒）
# RAW_AGENT_BASH_TIMEOUT_MS=120000

# 为 true/1 时，向模型挂载工具 claude_code / codex_exec / cursor_agent，可在会话内自主调用外部 CLI（需本机 PATH 有对应命令；默认每次调用需审批）
# RAW_AGENT_EXTERNAL_AI_TOOLS=1

# --- Self-heal（CLI：`npm run start:cli -- self-heal start`；HTTP：`POST /api/self-heal/start`）---
# 自愈子进程会自动把 node 同目录、/opt/homebrew/bin、/usr/local/bin、/usr/bin  prepend 到 PATH，缓解 spawn npm/git ENOENT。
# 仍失败可显式指定：RAW_AGENT_NPM_BIN、RAW_AGENT_GIT_BIN（绝对路径）。
# RAW_AGENT_NPM_BIN=
# RAW_AGENT_GIT_BIN=
# RAW_AGENT_SELF_HEAL_TEST_PRESET=unit
# RAW_AGENT_SELF_HEAL_CUSTOM_SCRIPT=myscript
# RAW_AGENT_SELF_HEAL_MAX_ITERATIONS=5
# 合并到当前目标分支并产生 merge commit；推远端为可选（需本机已配置 remote/凭证）
# RAW_AGENT_SELF_HEAL_AUTO_MERGE=0
# RAW_AGENT_SELF_HEAL_GIT_PUSH=0
# RAW_AGENT_SELF_HEAL_GIT_REMOTE=origin
# 合并后请求 supervisor 重启 daemon（需 `npm run start:supervised`，见 scripts/supervisor.mjs）
# RAW_AGENT_SELF_HEAL_AUTO_RESTART=0
# RAW_AGENT_SELF_HEAL_TARGET_BRANCH=main
# RAW_AGENT_SELF_HEAL_AGENT_ID=self-healer
# Allow self-heal agent to call claude_code/codex_exec/cursor_agent without approval
# (requires RAW_AGENT_EXTERNAL_AI_TOOLS=1 and the CLI to be on PATH)
# RAW_AGENT_SELF_HEAL_ALLOW_EXTERNAL_AI=0
# Daemon 启动时自动发起一次 self-heal（policy 仍来自下方 RAW_AGENT_SELF_HEAL_*；与「已有活跃 run」冲突时跳过）
# RAW_AGENT_SELF_HEAL_AUTO_START=0
# merge 前主仓有未提交改动时自动 git stash push -u，merge 成功后 stash pop（失败会 blocked 并提示）
# RAW_AGENT_SELF_HEAL_AUTO_STASH_MAIN=0
#
# 「持续自我进化」最小闭环（本地）：start:supervised + AUTO_MERGE + AUTO_RESTART + AUTO_STASH_MAIN；
# 远端同步：再开 SELF_HEAL_GIT_PUSH=1。「读论文→实验→合主线」尚无内置调度，需另做定时任务/Agent 会话编排。

# 设为 1 且使用 openai-compatible 时，daemon / runSession(stream) 可走 SSE 流式
# RAW_AGENT_STREAM=1

# 审批策略 JSON，例如: {"defaultRisky":true} 或 {"rules":[{"toolPattern":"write_*","match":"glob","when":"always"}]}
# RAW_AGENT_APPROVAL_POLICY=

# HTTP JSON-RPC MCP 地址，逗号或空格分隔
# RAW_AGENT_MCP_URLS=http://127.0.0.1:3030/mcp
# MCP stdio：JSON 数组，每项 { "command": "npx", "args": ["-y","@modelcontextprotocol/server-memory"] }
# RAW_AGENT_MCP_STDIO=
# 为 0 时不把 stdio 上 tools/list 展开成独立工具名（仍可有 mcp_list_resources / mcp_read_resource）
# RAW_AGENT_MCP_EXPAND_STDIO=1
# 为 1 时把 HTTP MCP 的 tools/list 也展开成 mcp_h0_* 工具
# RAW_AGENT_MCP_EXPAND_HTTP=0

# web_fetch：最大字节；默认拦截私网 IP，设为 1 允许（慎用）
# RAW_AGENT_WEB_FETCH_MAX_BYTES=2000000
# RAW_AGENT_WEB_FETCH_ALLOW_PRIVATE=0
# web_search：模板 URL，{query} 会被编码替换（不设则 web_search 工具仅返回说明）
# RAW_AGENT_WEB_SEARCH_URL=

# Jupyter：为 1 时启用 notebook_edit 工具
# RAW_AGENT_NOTEBOOK_TOOLS=0

# LSP：为 1 且提供 RAW_AGENT_LSP_COMMAND JSON，例如 {"command":"typescript-language-server","args":["--stdio"]}
# RAW_AGENT_LSP_ENABLED=0
# RAW_AGENT_LSP_COMMAND=

# 工具结果最大字符数（防止撑爆上下文）
# RAW_AGENT_TOOL_RESULT_MAX_CHARS=120000

# 审批策略文件（仓库根 .raw-agent-policy.yaml），与 RAW_AGENT_APPROVAL_POLICY 合并
# 见 policy-loader：bashCommandPatterns、pathRules

# 工具钩子：可执行脚本，stdin 一行 JSON（phase/tool/sessionId/input）；stdout JSON { block?, message?, input? }
# RAW_AGENT_HOOK_PRE_TOOL=
# RAW_AGENT_HOOK_POST_TOOL=
# RAW_AGENT_HOOK_TIMEOUT_MS=30000

# 可选 OTLP HTTP 导出（极简 span，非完整 SDK）
# RAW_AGENT_OTEL_HTTP_ENDPOINT=

# Daemon 请求体最大字节数
# RAW_AGENT_MAX_BODY_BYTES=2000000

# --- Capability Gateway（与 core 平级包 @ppeng/agent-capability-gateway，HTTP 前缀默认 /gateway/v1）---
# 设为 1 启用；见 gateway.config.example.json
# RAW_AGENT_GATEWAY_ENABLED=1
# RAW_AGENT_GATEWAY_PREFIX=/gateway/v1
# RAW_AGENT_GATEWAY_CONFIG=gateway.config.json
# 可选：X-Gateway-Token 或 Authorization: Bearer
# RAW_AGENT_GATEWAY_TOKEN=
# 定时 RSS 学习（每日 UTC 整点后首次 tick 跑一次）
# RAW_AGENT_GATEWAY_LEARN_ENABLED=1
# RAW_AGENT_GATEWAY_LEARN_HOUR_UTC=6

# 飞书 / Lark 机器人发消息（channels 里 type=feishu_bot 或 Feishu 事件回复）
# RAW_AGENT_FEISHU_APP_ID=
# RAW_AGENT_FEISHU_APP_SECRET=
# 国际版 Lark 时可改 API 根，例如 https://open.larksuite.com
# RAW_AGENT_FEISHU_API_BASE=https://open.feishu.cn
